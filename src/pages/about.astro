---
export const prerender = true;

import {
  BaseLayout,
  Hero,
  About,
  Experience,
  Education,
  Projects,
  Section,
  ThemeSwitch,
  KeyboardManager,
} from "dev-portfolio-ai";
import type { ExperienceItem, EducationItem, ProjectItem, KeyboardCommand } from "dev-portfolio-ai";
import { themeConfig } from "../site.config";
import {
  basics,
  work,
  education,
  patents,
  projects,
  managerToolbox,
  technicalSkills,
  formatDateRange,
} from "../resume";

// Map resume.ts work data to ExperienceItem[]
const experienceItems: ExperienceItem[] = work.map((job) => ({
  name: job.company,
  position: job.position,
  url: job.url,
  startDate: job.startDate,
  endDate: job.endDate || null,
  summary: job.summary || undefined,
  responsibilities: job.responsibilities.length > 0 ? job.responsibilities : undefined,
  achievements: job.achievements.length > 0 ? job.achievements : undefined,
  location: job.location,
}));

// Map resume.ts education data to EducationItem[]
const educationItems: EducationItem[] = education.map((edu) => ({
  institution: edu.institution,
  url: edu.url,
  area: `${edu.studyType}, ${edu.area}`,
  startDate: edu.startDate,
  endDate: edu.endDate,
}));

// Map resume.ts projects data to ProjectItem[]
const projectItems: ProjectItem[] = projects.map((p) => ({
  name: p.name,
  description: p.description,
  url: p.url,
  isActive: true,
  github: p.url,
}));

// Machine-readable endpoints
const machineReadable = [
  { name: "JSON Resume", url: "/resume.json", description: "Structured resume data" },
  { name: "LLMs.txt", url: "/llms.txt", description: "LLM-friendly resume" },
  { name: "MCP Server", url: "/.well-known/mcp.json", description: "Model Context Protocol" },
  { name: "Skills", url: "/skills.json", description: "Agent Skills Discovery" },
];

const docIcon = `<svg style="margin-right: 8px" width="16" height="16" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" /></svg>`;

const extraCommands: KeyboardCommand[] = machineReadable.map((item) => ({
  id: item.name.toLowerCase().replace(/\s+/g, "-"),
  title: `View ${item.name}`,
  icon: docIcon,
  section: "Machine-Readable",
  url: item.url,
}));
---

<BaseLayout title={`About: ${basics.name}`} config={themeConfig} description={basics.summary}>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Person",
    "name": basics.name,
    "url": basics.url,
    "image": basics.image,
    "jobTitle": basics.label,
    "worksFor": {
      "@type": "Organization",
      "name": work[0].company,
      "url": work[0].url,
    },
    "address": {
      "@type": "PostalAddress",
      "addressLocality": basics.location.city,
      "addressRegion": basics.location.region,
      "addressCountry": basics.location.countryCode,
    },
    "email": basics.email,
    "telephone": basics.phone.replace(/[() ]/g, ""),
    "sameAs": basics.profiles.map((p) => p.url),
    "alumniOf": education.map((e) => ({
      "@type": "CollegeOrUniversity",
      "name": e.institution,
      "url": e.url,
    })),
    "knowsAbout": technicalSkills.flatMap((s) => s.keywords).slice(0, 20),
  })} />

  <main class="relative grid max-w-7xl gap-12 p-8 max-sm:py-16 md:grid-cols-6 md:p-16 xl:gap-24 print:max-w-none print:grid-cols-1 print:gap-6">
    <div class="space-y-6 md:col-span-2 print:col-span-1 print:grid print:grid-cols-2 print:gap-5 print:space-y-0">
      <Hero
        name={basics.name}
        label={basics.label}
        image="/avatar.jpg"
        email={basics.email}
        phone={basics.phone}
        location={{ city: basics.location.city, region: basics.location.region }}
        profiles={basics.profiles}
      />
      <About summary={basics.summary} />
      <ThemeSwitch />

      <div class="no-print flex flex-col gap-3">
        <h3 class="flex items-center gap-2 text-sm font-medium text-skin-base">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 8V4H8" />
            <rect width="16" height="12" x="4" y="8" rx="2" />
            <path d="M2 14h2" />
            <path d="M20 14h2" />
            <path d="M15 13v2" />
            <path d="M9 13v2" />
          </svg>
          Machine-Readable
        </h3>
        <div class="flex flex-wrap gap-2">
          {machineReadable.map((item) => (
            <a
              href={item.url}
              target="_blank"
              rel="noopener noreferrer"
              title={item.description}
              class="inline-flex items-center gap-1.5 rounded-md border border-skin-hue/20 bg-skin-button-accent/10 px-2.5 py-1 text-xs text-skin-hue transition-colors hover:bg-skin-button-accent hover:text-skin-inverted"
            >
              {item.name}
            </a>
          ))}
        </div>
      </div>
    </div>
    <div class="space-y-12 md:col-span-4 print:col-span-1 print:grid print:grid-cols-4 print:gap-2 print:space-y-0">
      <Experience items={experienceItems} className="print:col-span-3" />
      <Projects items={projectItems} className="print:hidden" />

      <Section title="Patents">
        <div class="grid grid-cols-1 gap-3 md:grid-cols-2 print:block">
          {patents.map((patent) => (
            <div role="contentinfo" class="ring-skin-muted relative flex flex-col rounded-md bg-skin-button-muted/50 p-5 shadow-sm ring-1 print:rounded-none print:bg-transparent print:p-0 print:shadow-none print:ring-0">
              <div class="flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 print:hidden">
                  <path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5" />
                  <path d="M9 18h6" />
                  <path d="M10 22h4" />
                </svg>
                <span class="text-lg print:text-base font-medium">{patent.name}</span>
              </div>
              <p class="py-3 print:py-1 text-sm text-skin-base">
                Systems and methods for processing natural language queries through dynamic knowledge graphs to enable intelligent, conversational interactions with enterprise resource planning data.
              </p>
              <div class="flex gap-3 text-xs text-skin-muted">
                <span>Filed: {formatDateRange(patent.filedDate, "").split(" — ")[0]}</span>
                <span>Issued: {formatDateRange(patent.issuedDate, "").split(" — ")[0]}</span>
              </div>
              <div class="mt-3 print:mt-1 flex flex-wrap gap-2">
                {patent.numbers.map((n) => (
                  <a href={n.url} target="_blank" rel="noopener noreferrer" class="group flex items-center gap-1 text-xs text-skin-hue decoration-dotted underline-offset-[5px] hover:underline">
                    {n.id}
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="inline-block w-3 h-3 transition-transform group-hover:-translate-y-0.5 group-hover:translate-x-0.5 print:hidden" aria-hidden="true">
                      <path fill-rule="evenodd" d="M5.22 14.78a.75.75 0 001.06 0l7.22-7.22v5.69a.75.75 0 001.5 0v-7.5a.75.75 0 00-.75-.75h-7.5a.75.75 0 000 1.5h5.69l-7.22 7.22a.75.75 0 000 1.06z" clip-rule="evenodd"></path>
                    </svg>
                  </a>
                ))}
              </div>
            </div>
          ))}
        </div>
      </Section>

      <Section title="Manager Toolbox">
        <ul class="text-skin-muted [&>li]:ml-4 flex list-disc flex-col gap-2 print:gap-0 text-sm print:text-xs">
          {managerToolbox.map((cat) => (
            <li>
              <strong class="text-skin-base">{cat.name}:</strong>{" "}
              {cat.keywords.join(", ")}
            </li>
          ))}
        </ul>
      </Section>

      <Section title="Technical Skills">
        <ul class="text-skin-muted [&>li]:ml-4 flex list-disc flex-col gap-2 print:gap-0 text-sm print:text-xs">
          {technicalSkills.map((cat) => (
            <li>
              <strong class="text-skin-base">{cat.name}:</strong>{" "}
              {cat.keywords.join(", ")}
            </li>
          ))}
        </ul>
      </Section>

      <Education items={educationItems} className="order-first" />
    </div>
  </main>

  <KeyboardManager profiles={basics.profiles} extraCommands={extraCommands} />
</BaseLayout>

<style>
  @page {
    size: auto;
    margin: 0mm;
  }
  main {
    margin: auto;
    width: 100%;
  }
  li::marker {
    color: var(--color-accent);
  }
</style>
