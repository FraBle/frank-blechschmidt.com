---
export const prerender = true;

import {
  BaseLayout,
  Hero,
  About,
  Experience,
  Education,
  Projects,
  Section,
  ThemeSwitch,
  KeyboardManager,
} from "dev-portfolio-ai";
import type { ExperienceItem, EducationItem, ProjectItem } from "dev-portfolio-ai";
import { themeConfig } from "../site.config";
import {
  basics,
  work,
  education,
  patents,
  projects,
  managerToolbox,
  technicalSkills,
  formatDateRange,
} from "../resume";

// Map resume.ts work data to ExperienceItem[]
const experienceItems: ExperienceItem[] = work.map((job) => ({
  name: job.company,
  position: job.position,
  url: job.url,
  startDate: job.startDate,
  endDate: job.endDate || null,
  summary: job.summary || undefined,
  highlights: job.highlights,
  location: job.location,
}));

// Map resume.ts education data to EducationItem[]
const educationItems: EducationItem[] = education.map((edu) => ({
  institution: edu.institution,
  url: edu.url,
  area: `${edu.studyType}, ${edu.area}`,
  endDate: edu.endDate,
}));

// Map resume.ts projects data to ProjectItem[]
const projectItems: ProjectItem[] = projects.map((p) => ({
  name: p.name,
  description: p.description,
  url: p.url,
  isActive: true,
  github: p.url,
}));
---

<BaseLayout title={`About: ${basics.name}`} config={themeConfig} description={basics.summary}>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Person",
    "name": basics.name,
    "url": basics.url,
    "image": basics.image,
    "jobTitle": basics.label,
    "worksFor": {
      "@type": "Organization",
      "name": work[0].company,
      "url": work[0].url,
    },
    "address": {
      "@type": "PostalAddress",
      "addressLocality": basics.location.city,
      "addressRegion": basics.location.region,
      "addressCountry": basics.location.countryCode,
    },
    "email": basics.email,
    "telephone": basics.phone.replace(/[() ]/g, ""),
    "sameAs": basics.profiles.map((p) => p.url),
    "alumniOf": education.map((e) => ({
      "@type": "CollegeOrUniversity",
      "name": e.institution,
      "url": e.url,
    })),
    "knowsAbout": technicalSkills.flatMap((s) => s.keywords).slice(0, 20),
  })} />

  <main class="relative grid max-w-7xl gap-12 p-8 max-sm:py-16 md:grid-cols-6 md:p-16 xl:gap-24 print:max-w-none print:grid-cols-1 print:gap-6">
    <div class="space-y-6 md:col-span-2 print:col-span-1 print:grid print:grid-cols-2 print:gap-5 print:space-y-0">
      <Hero
        name={basics.name}
        label={basics.label}
        image="/avatar.jpg"
        email={basics.email}
        phone={basics.phone}
        location={{ city: basics.location.city, region: basics.location.region }}
        profiles={basics.profiles}
      />
      <About summary={basics.summary} />
      <ThemeSwitch />
    </div>
    <div class="space-y-12 md:col-span-4 print:col-span-1 print:grid print:grid-cols-4 print:gap-2 print:space-y-0">
      <Experience items={experienceItems} className="print:col-span-3" />
      <Projects items={projectItems} className="print:hidden" />

      <Section title="Patents">
        {patents.map((patent) => (
          <div class="flex flex-col gap-1 text-sm">
            <h4 class="font-medium">{patent.name}</h4>
            <p class="text-skin-muted">
              Filed: {formatDateRange(patent.filedDate, "").split(" — ")[0]} |
              Issued: {formatDateRange(patent.issuedDate, "").split(" — ")[0]}
            </p>
            <div class="flex flex-wrap gap-2">
              {patent.numbers.map((n) => (
                <a href={n.url} target="_blank" class="text-xs text-skin-hue hover:underline">{n.id}</a>
              ))}
            </div>
          </div>
        ))}
      </Section>

      <Section title="Manager Toolbox" className="print:hidden">
        <ul class="flex flex-wrap gap-x-6 gap-y-3 text-sm">
          {managerToolbox.map((cat) => (
            <li>
              <strong class="text-skin-base">{cat.name}:</strong>{" "}
              <span class="text-skin-muted">{cat.keywords.join(", ")}</span>
            </li>
          ))}
        </ul>
      </Section>

      <Section title="Technical Skills" className="print:hidden">
        <ul class="flex flex-wrap gap-x-6 gap-y-3 text-sm">
          {technicalSkills.map((cat) => (
            <li>
              <strong class="text-skin-base">{cat.name}:</strong>{" "}
              <span class="text-skin-muted">{cat.keywords.join(", ")}</span>
            </li>
          ))}
        </ul>
      </Section>

      <Education items={educationItems} className="order-first" />
    </div>
  </main>

  <KeyboardManager profiles={basics.profiles} />
</BaseLayout>

<style>
  @page {
    size: auto;
    margin: 0mm;
  }
  main {
    margin: auto;
    width: 100%;
  }
</style>
