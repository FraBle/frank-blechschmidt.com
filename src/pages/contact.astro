---
export const prerender = true;

import { BaseLayout } from "astro-researcher-theme";
import { themeConfig } from "../site.config";
import { basics } from "../resume";
---

<BaseLayout title={`Contact: ${basics.name}`} config={themeConfig} description={`Get in touch with ${basics.name}. Email, phone, and social media links.`}>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ContactPage",
    "name": `Contact ${basics.name}`,
    "url": `${basics.url}/contact`,
    "mainEntity": {
      "@type": "Person",
      "name": basics.name,
      "email": basics.email,
      "telephone": basics.phone.replace(/[() ]/g, ""),
      "sameAs": basics.profiles.map((p) => p.url),
    },
  })} />
  <div class="container">
    <h2>Contact</h2>

    <ul>
      <li>Email: <a href={`mailto:${basics.email}`}>{basics.email}</a></li>
      <li>Phone: <a href={`tel:${basics.phone.replace(/[() ]/g, "")}`}>{basics.phone}</a></li>
    </ul>

    <hr />

    <h2>Links</h2>

    <ol>
      {basics.profiles.map((profile) => (
        <li><a href={profile.url}>{profile.network}</a></li>
      ))}
    </ol>
  </div>
</BaseLayout>
