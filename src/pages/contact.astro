---
export const prerender = true;

import { BaseLayout, Section } from "dev-portfolio-ai";
import { themeConfig } from "../site.config";
import { basics } from "../resume";
---

<BaseLayout title={`Contact: ${basics.name}`} config={themeConfig} description={`Get in touch with ${basics.name}. Email, phone, and social media links.`}>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ContactPage",
    "name": `Contact ${basics.name}`,
    "url": `${basics.url}/contact`,
    "mainEntity": {
      "@type": "Person",
      "name": basics.name,
      "email": basics.email,
      "telephone": basics.phone.replace(/[() ]/g, ""),
      "sameAs": basics.profiles.map((p) => p.url),
    },
  })} />

  <main class="relative max-w-7xl p-8 md:p-16">
    <Section title="Contact">
      <ul class="flex flex-col gap-3 text-sm">
        <li>
          <span class="text-skin-muted">Email:</span>{" "}
          <a href={`mailto:${basics.email}`} class="text-skin-hue hover:underline">{basics.email}</a>
        </li>
        <li>
          <span class="text-skin-muted">Phone:</span>{" "}
          <a href={`tel:${basics.phone.replace(/[() ]/g, "")}`} class="text-skin-hue hover:underline">{basics.phone}</a>
        </li>
      </ul>
    </Section>

    <Section title="Links" className="mt-8">
      <ul class="flex flex-col gap-2 text-sm">
        {basics.profiles.map((profile) => (
          <li>
            <a href={profile.url} target="_blank" rel="noopener noreferrer" class="text-skin-hue hover:underline">
              {profile.network}
            </a>
          </li>
        ))}
      </ul>
    </Section>
  </main>
</BaseLayout>

<style>
  main {
    margin: auto;
    width: 100%;
  }
</style>
