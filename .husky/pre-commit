#!/usr/bin/env sh

branch_name="$(git symbolic-ref --quiet --short HEAD || true)"

# Allow detached HEAD contexts (e.g. CI or temporary checkouts).
if [ -n "$branch_name" ] && echo "$branch_name" | grep -q "/"; then
  echo "Invalid branch name: '$branch_name'"
  echo "Branch names must not contain '/'."
  exit 1
fi

if command -v qlty >/dev/null 2>&1; then
  qlty fmt --trigger pre-commit --index-file="$GIT_INDEX_FILE"
fi
bun run test
bun run lint-staged
