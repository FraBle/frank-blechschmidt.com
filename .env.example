# Sentry DSN (from Sentry project settings)
# PUBLIC_SENTRY_DSN=

# Sentry auth token (for source map uploads during build)
# SENTRY_AUTH_TOKEN=

# Umami Analytics website ID (from Umami Cloud dashboard)
# PUBLIC_UMAMI_WEBSITE_ID=

# CI/CD secrets (configured in GitHub Actions, not needed locally)
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=
